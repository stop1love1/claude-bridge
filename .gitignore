# bridge artefacts
*.log
.DS_Store
.playwright-mcp/
.uploads/
.bridge-state/

# Go build artefacts (migration/go branch)
/bin/
/dist/
/web/dist/
*.exe
*.exe~
*.test
*.out
go.work.sum

# embed staging — `make embed-web` copies web/dist/ here at build
# time; we keep .gitkeep tracked so //go:embed all:dist compiles on a
# fresh clone before the first frontend build.
/internal/web/dist/*
!/internal/web/dist/.gitkeep

# local-only bridge runtime state — per-task meta.json + spawned sessions
/sessions/*
!/sessions/.gitkeep

# user-local Claude Code allowlist — shouldn't be shared across machines
/.claude/settings.local.json

# uploaded / pasted images at the bridge root only (don't shadow
# tracked assets under public/, app/, etc.)
/*.png
/*.jpeg
/*.jpg

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
# bun.lock is intentionally COMMITTED so production installs are
# reproducible. The historical project template ignored every lockfile
# variant; we only need our own.
bun.lockb
package-lock.json
pnpm-lock.yaml

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (the .example template is shareable — the rest aren't)
.env*
!.env.example

# defense-in-depth: bridge.json normally lives at ~/.claude/bridge.json
# (outside this tree). If anyone copies a sample into the repo root for
# testing, never commit it — it carries password hashes, the HMAC
# session secret, the internal-bypass token, the ngrok authtoken, and
# Telegram MTProto session strings.
/bridge.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# misc
*.pem
