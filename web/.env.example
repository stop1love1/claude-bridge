# Web SPA — Vite environment variables.
# Copy to `.env.local` (gitignored) and uncomment what you need.

# Override the API base URL when serving the SPA from a different
# origin than the bridge backend. Leave empty for same-origin (the
# default — the SPA assumes it's served by the bridge itself).
# VITE_API_BASE=http://localhost:7777

# Operator opt-in for the "Skip permissions" composer mode.
# When set to "1":
#   - the ChatSettingsMenu shows the "Skip permissions" option
#   - new sessions default to bypassPermissions instead of `default`
# Leave at "0" (or unset) on multi-user / shared workstations — the
# server enforces the same gate, so spoofed requests are rejected.
VITE_BRIDGE_ALLOW_BYPASS=0
