## Bridge dev server
PORT=7777
ALLOWED_DEV_ORIGINS=

## Telegram notifier (optional — leave both blank to disable)
##   1. Talk to @BotFather → /newbot, copy the token below
##   2. Add the bot to your chat / group, then call
##      https://api.telegram.org/bot<TOKEN>/getUpdates and copy the
##      `chat.id` of the message you sent
##   3. Restart `bun dev` to pick up the env, then click the small
##      paper-plane icon in /apps to send a test message
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
